// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Setting {
  id            String  @id @default("default")
  storeName     String  @default("My Store")
  address       String?
  phone         String?
  email         String?
  website       String?
  logoPath      String?
  taxRate       Float   @default(0)
  currency      String  @default("Rs.")
  receiptFooter String  @default("Thank you! Come again")
}

model Supplier {
  id            String            @id @default(uuid())
  name          String
  contactPerson String
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime          @default(now())
  invoices      SupplierInvoice[]
  products      Product[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Warehouse {
  id        String            @id @default(uuid())
  name      String            @unique
  location  String?
  capacity  Int?
  manager   String?
  phone     String?
  createdAt DateTime          @default(now())
  invoices  SupplierInvoice[]
  products  Product[]
}

model Product {
  id            String     @id @default(uuid())
  name          String
  barcode       String     @unique
  price         Float      @default(0)
  stock         Float      @default(0)
  unit          String     @default("pcs")
  expiryDate    DateTime?
  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id])
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  rackNo        String?
  imagePath     String?
  detail        String?
  mfgDate       DateTime?
  lowStockAlert Float?     @default(5)
  supplierPrice Float?     @default(0)
  model         String?
  supplierId    String?
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])
  createdAt     DateTime   @default(now())
  saleItems     SaleItem[]
}

model SaleTransaction {
  id          String     @id @default(uuid())
  receiptNo   String     @unique
  totalAmount Float      @default(0)
  paidAmount  Float      @default(0)
  change      Float      @default(0)
  discount    Float      @default(0)
  tax         Float      @default(0)
  createdAt   DateTime   @default(now())
  items       SaleItem[]
}

model SaleItem {
  id        String          @id @default(uuid())
  saleId    String
  productId String?
  name      String
  barcode   String?
  quantity  Float
  price     Float
  total     Float
  sale      SaleTransaction @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id])
}

model SupplierInvoice {
  id          String                @id @default(uuid())
  invoiceNo   String                @unique
  supplierId  String
  warehouseId String
  date        DateTime
  imagePath   String?
  grandTotal  Float                 @default(0)
  paidAmount  Float                 @default(0)
  due         Float                 @default(0)
  createdAt   DateTime              @default(now())
  supplier    Supplier              @relation(fields: [supplierId], references: [id])
  warehouse   Warehouse             @relation(fields: [warehouseId], references: [id])
  items       SupplierInvoiceItem[]
}

model SupplierInvoiceItem {
  id        String          @id @default(uuid())
  invoiceId String
  itemName  String
  quantity  Float
  rate      Float
  total     Float
  invoice   SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Customer {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  address       String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  category    String
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
}

model Loan {
  id           String   @id @default(uuid())
  partnerName  String
  type         String // Payable, Receivable
  amount       Float
  interestRate Float    @default(0)
  dueDate      DateTime
  status       String   @default("Active")
  description  String?
  createdAt    DateTime @default(now())
}

model Staff {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  role      String
  salary    Float
  dateHired DateTime
  status    String   @default("Active")
  createdAt DateTime @default(now())
}
